{
  "expo": {
    "name": "Musing",
    "slug": "thoughts-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf9f5"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "允许 Musing 识别你的语音。",
        "NSMicrophoneUsageDescription": "允许 Musing 使用麦克风进行语音转写。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#faf9f5"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anonymous.thoughtsapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "允许 Musing 使用你的麦克风录制想法。"
        }
      ],
      [
        "@siteed/audio-studio",
        {
          "iosConfig": {
            "microphoneUsageDescription": "允许 Musing 使用麦克风进行语音转写。"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/SourceSerif4-Semibold.ttf",
            "./assets/fonts/LXGWNeoXiHei.ttf"
          ]
        }
      ]
    ]
  }
}
